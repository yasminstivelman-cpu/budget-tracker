# NextAuth
# generate with: openssl rand -hex 32
AUTH_SECRET=your-nextauth-secret-here
AUTH_URL=http://localhost:3000

# Google OAuth — from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Contributor access token — generate with: openssl rand -hex 32
CONTRIBUTOR_TOKEN=

# Owner spreadsheet config — filled in automatically after Owner completes /setup
OWNER_SPREADSHEET_ID=
OWNER_SHEET_NAME=Expenses
OWNER_REFRESH_TOKEN=

# Telegram Bot integration
TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
ALLOWED_TELEGRAM_IDS=
